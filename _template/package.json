{
  "name": "my-dsa-lab",
  "version": "1.0.0",
  "description": "A zero-config, test-driven DSA laboratory",
  "type": "module",
  "scripts": {
    "start": "tsx scripts/dashboard.ts",
    "make": "tsx scripts/generate.ts",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --watchAll",
    "test:run": "node --experimental-vm-modules node_modules/.bin/jest --verbose",
    "notes": "nodemon --exec tsx scripts/serve-notes.ts",
    "bench": "tsx scripts/dashboard.ts --bench"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/marked": "^5.0.2",
    "@types/node": "^25.0.3",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "express": "^5.2.1",
    "jest": "^30.2.0",
    "marked": "^17.0.5",
    "nodemon": "^3.1.11",
    "prompts": "^2.4.2",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
