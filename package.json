{
  "name": "create-dsa-lab",
  "version": "1.2.0",
  "description": "Scaffold a zero-config, test-driven DSA laboratory in seconds",
  "bin": {
    "create-dsa-lab": "./bin/cli.js"
  },
  "type": "module",
  "files": [
    "bin/",
    "_template/"
  ],
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --coverage",
    "release": "node scripts/release.js"
  },
  "keywords": [
    "dsa",
    "cli",
    "scaffold",
    "algorithms",
    "data-structures",
    "leetcode",
    "tdd",
    "create",
    "generator"
  ],
  "author": "Yashvardhan Thanvi",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YTTHEMIGHTY/create-dsa-lab.git"
  },
  "homepage": "https://github.com/YTTHEMIGHTY/create-dsa-lab#readme",
  "bugs": {
    "url": "https://github.com/YTTHEMIGHTY/create-dsa-lab/issues"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "prompts": "^2.4.2",
    "chalk": "^5.4.1"
  },
  "devDependencies": {
    "jest": "^30.2.0",
    "@jest/globals": "^30.2.0"
  },
  "jest": {
    "testPathIgnorePatterns": [
      "/node_modules/",
      "/_template/"
    ]
  }
}
